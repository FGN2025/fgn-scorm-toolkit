{
  "name": "fgn-scorm-toolkit",
  "version": "0.1.0",
  "private": true,
  "description": "Toolkit for authoring and exporting SCORM-compliant courses from FGN sim-based challenges.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/FGN2025/fgn-scorm-toolkit.git"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
